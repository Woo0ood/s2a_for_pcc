# Copy to export-worker.env (gitignored) and fill in. Holds BOTH deploy-time SSH
# info and the worker runtime config. deploy.sh ships only the runtime vars to the
# container; the DEPLOY_*/WORKER_* vars stay local.

# ───── deploy-time (local only) ─────
DEPLOY_SSH=newdc                          # ssh-config alias (recommended) or user@host
DEPLOY_REMOTE_DIR=/opt/s2a-export-worker
WORKER_DOCKER_NETWORK=                     # the docker network clickhouse is on (so CH_DSN can use clickhouse:9000)
WORKER_PUBLISH=0.0.0.0:8088:8088          # host-port mapping; front this with your own reverse proxy → public HTTPS
WORKER_MEM_LIMIT=2g
# WORKER_IMAGE_TAG=                        # default: git short sha
# CONTAINER_NAME=s2a-export-worker

# ───── worker runtime (shipped to the container as --env-file) ─────
EXPORT_WORKER_LISTEN=:8088
EXPORT_WORKER_TOKEN=ca2677a2190f50d80cbbf262c8afc5ba   # same value goes in sub2api's payload-audit config form
CH_DSN=clickhouse://USER:PASS@clickhouse:9000/lax_s1   # internal CH addr on WORKER_DOCKER_NETWORK
CH_TABLE=payload_audit_logs
BLOB_S3_ENDPOINT=https://s3.bj1.r.v2c.link:39000
BLOB_S3_REGION=auto
BLOB_S3_BUCKET=lax-payload-audit-blob
BLOB_S3_ACCESS_KEY_ID=
BLOB_S3_SECRET_ACCESS_KEY=
BLOB_S3_PREFIX=payload-audit/
BLOB_S3_FORCE_PATH_STYLE=true
EXPORT_RESULT_PREFIX=payload-audit/exports/
RENDER_TIMEOUT_MINUTES=10
CONV_WINDOW_DAYS=7
